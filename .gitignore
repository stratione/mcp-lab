# Playwright MCP test artifacts (ad-hoc browser drives during development).
# Match anywhere — earlier patterns only covered scripts/, but artifacts also
# land at the repo root when a session is run from there.
**/.playwright-mcp/
walkthrough-*.png
scripts/*.png
